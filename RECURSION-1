Print Table of 2, n=10 times
**************************************************************************************************************************
#include <iostream>
using namespace std;

void printTable(int n, int i = 1)
{
    if (i > n) return;
    cout << "2 x " << i << " = " << 2 * i << endl;
    printTable(n, i + 1);
}

int main()
{
    int n = 10;
    printTable(n);
    return 0;
}
