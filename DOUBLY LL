#include <iostream>
using namespace std;

class Node 
{
public:
    int value;
    Node* previous;
    Node* next;

    Node(int val = 0, Node* prev = nullptr, Node* nxt = nullptr)
        : value(val), previous(prev), next(nxt) {}
};

void insertAtStart(Node*& head, Node*& tail, int val) 
{
    Node* newNode = new Node(val);
    if (head == nullptr) 
    {
        head = tail = newNode;
    } else {
        newNode->next = head;
        head->previous = newNode;
        head = newNode;
    }
}

int length(Node* head) 
{
    int count = 0;
    Node* current = head;
    while (current != nullptr) 
    {
        count++;
        current = current->next;
    }
    return count;
}

int main() 
{
    Node* head = nullptr;
    Node* tail = nullptr;

    insertAtStart(head, tail, 1);
    insertAtStart(head, tail, 2);
    insertAtStart(head, tail, 3);

    cout << length(head) << endl;
    Node* current = head;
    while (current != nullptr)
     {
        Node* temp = current;
        current = current->next;
        delete temp;
    }

    return 0;
}
