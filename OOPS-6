Virtual Function
****************************************************************************************************************************
#include <iostream>
using namespace std;

class Human
{
public:
    virtual void display() = 0;
};

class Person : public Human
{
public:
    void display()
    {
        cout << "hello" << endl;
    }
};

int main() {
    Person p;
    p.display();
    return 0;
}
