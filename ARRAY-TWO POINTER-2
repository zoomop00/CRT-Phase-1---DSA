Two Sums & Two Problems
*************************************************************************************************************************
#include <iostream>
#include <vector>
using namespace std;

class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        int i = 0;
        int j = (int)nums.size() - 1;
        vector<int> arr;

        while (i < j) {
            int sum = nums[i] + nums[j];
            if (sum == target) {
                arr.push_back(i + 1);
                arr.push_back(j + 1);
                return arr;
            } else if (sum > target) {
                j--;
            } else {
                i++;
            }
        }
        return arr;
    }
};

int main() {
    Solution solution;
    vector<int> nums = {2, 7, 11, 15};
    int target = 9;

    vector<int> answer = solution.twoSum(nums, target);
    if (!answer.empty()) {
        cout << answer[0] << " and " << answer[1] << endl;
    } else {
        cout << "No solution found." << endl;
    }

    return 0;
}
