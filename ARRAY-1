Print odd & even sum of all array elements?
***********************************************************************************************************************
#include <iostream>
using namespace std;

int main() 
{
    int arr[] = {1, 2, 3, 4};
    int n = sizeof(arr) / sizeof(arr[0]);
    int odd = 0, even = 0;

    for(int i = 0; i < n; i++) {
        if(arr[i] % 2 == 0)
            even += arr[i];
        else
            odd += arr[i];
    }

    cout << "odd: " << odd << endl;
    cout << "even: " << even << endl;

    return 0;
}
