Liner Search
***************************************************************************************************************************
#include <iostream>
using namespace std;

bool linearSearch(int arr[], int n, int target) {
    for (int i = 0; i < n; i++) {
        if (arr[i] == target) {
            return true;
        }
    }
    return false;
}

int main() 
{
    int n = 5;
    int arr[n] = {0};

    for (int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    int target;
    cin >> target;

    if (linearSearch(arr, n, target)) {
        cout << "true\n";
    } else {
        cout << "false\n";
    }

    return 0;
}
