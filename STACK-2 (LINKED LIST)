PUSH(),POP(),EMPTY(),TOP() USING LINKED LIST
*************************************************************************************************************************
#include <iostream>
using namespace std;

class node {
public:
    int value;
    node* next;
    node(int v) {
        value = v;
        next = nullptr;
    }
};

class stack {
    node* head;
public:
    stack() {
        head = nullptr;
    }
    void push(int v) {
        node* n = new node(v);
        n->next = head;
        head = n;
    }
    void pop() {
        if (head != nullptr) {
            node* n = head->next;
            delete head;
            head = n;
        }
    }
    bool empty() {
        return head == nullptr;
    }
    int top() {
        if (head != nullptr)
            return head->value;
        throw std::runtime_error("Stack is empty");
    }
};

int main() {
    stack st;
    st.push(1);
    st.push(2);
    st.push(3);

    while (!st.empty()) {
        cout << st.top() << " ";
        st.pop();
    }
    return 0;
}
