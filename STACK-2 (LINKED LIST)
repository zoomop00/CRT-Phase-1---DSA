PUSH(),POP() USING LINKED LIST
*************************************************************************************************************************
#include <iostream>
using namespace std;

class stack {
    struct node {
        int data;
        node* next;
        node(int v) {
            data = v;
            next = nullptr;
        }
    };

    node* head;

public:
    stack() {
        head = nullptr;
    }

    void push(int v) {
        node* n = new node(v);
        n->next = head;
        head = n;
    }

    void pop() {
        if (head == nullptr) {
            cout << "\n";
            return;
        }
        node* temp = head;
        head = head->next;
        delete temp;
    }

    bool empty() {
        return head == nullptr;
    }

    int top() {
        if (head == nullptr) {
            cout << "\n";
            return -1;
        }
        return head->data;
    }

    void display() {
        node* temp = head;
        while (temp != nullptr) {
            cout << temp->data << " ";
            temp = temp->next;
        }
        cout << endl;
    }
};

int main() 
{
    stack st;
    st.push(10);
    st.push(20);
    st.push(30);

    st.display();

    st.pop();
    st.display();

    cout << "Top element: " << st.top() << endl;

    return 0;
}
