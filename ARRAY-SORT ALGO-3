Selection Sort
************************************************************************************************************************
#include <iostream>
using namespace std;

int main() 
{
    int n = 5;
    int arr[5];
    
    cout << "Enter 5 elements: ";
    for(int i = 0; i < n; i++)
    {
        cin >> arr[i];
    }
    
    for(int i = 0; i < n - 1; i++)
    {
        int min_ele_index = i;
        for(int j = i + 1; j < n; j++)
        {
            if(arr[j] < arr[min_ele_index])
            {
                min_ele_index = j;
            }
        }
        if(min_ele_index != i)
        {
            swap(arr[i], arr[min_ele_index]);
        }
    }

    for(int i = 0; i < n; i++)
    {
        cout << arr[i] << " ";
    }
    return 0;
}
