Binary Search
*************************************************************************************************************************
#include <iostream>
using namespace std;

bool binarySearch( int arr[], int n, int target ) {
    int left = 0, right = n - 1;
    
    while ( left <= right ) {
        int mid = ( left + right ) / 2;
        if ( arr[mid] == target )
            return true;
        else if ( arr[mid] < target )
            left = mid + 1;
        else
            right = mid - 1;
    }
    return false;
}
int main() {
    
    int arr[] = { 1, 2, 3, 4, 5, 6 };
    int target = 6;
    cout << ( binarySearch( arr, 6, target ) ? "true\n" : "false\n" );
    return 0;
}
