PUSH(),POP(),EMPTY(),TOP() USING ARRAY
**************************************************************************************************************************
#include <iostream>
#include <vector>
using namespace std;

class Stack {
    vector<int> arr;
public:
    void push(int v) {
        arr.push_back(v);
    }
    void pop() {
        if (!arr.empty()) {
            arr.pop_back();
        }
    }
    bool empty() {
        return arr.empty();
    }
    int top() {
        if (!arr.empty())
            return arr.back();
        throw runtime_error("Stack is empty");
    }
};

int main() {
    Stack s;
    s.push(10);
    s.push(20);
    cout << "Top element: " << s.top() << endl;
    s.pop();
    cout << "Top element after pop: " << s.top() << endl;
    return 0;
}
