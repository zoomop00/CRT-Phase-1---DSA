Two Sum
************************************************************************************************************************
#include <iostream>
#include <vector>
using namespace std;

class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        vector<int> arr;
        for (int i = 0; i < (int)nums.size() - 1; i++) {
            for (int j = i + 1; j < (int)nums.size(); j++) {
                if (nums[i] + nums[j] == target) {
                    arr.push_back(i);
                    arr.push_back(j);
                    return arr;
                }
            }
        }
        return arr;
    }
};

int main() {
    Solution solution;
    vector<int> nums = {2, 7, 11, 15};
    int target = 9;

    vector<int> answer = solution.twoSum(nums, target);
    if (!answer.empty()) {
        cout << nums[answer[0]] << " and " << nums[answer[1]] << endl;
    } else {
        cout << "No solution found." << endl;
    }

    return 0;
}
